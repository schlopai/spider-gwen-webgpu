node_modules
dist
dist-ssr
*.local
.DS_Store
*.log

# Generated build output — regenerated by the build, never committed:
#   gen/chunk.bin       — tish engine bytecode (src/*.tish via `tish build --target bytecode`)
#   gen/spider-gwen.glb — optimized model (built from assets-src/ by `npm run build:assets`)
gen/

# Vendor runtime IS committed (prebuilt wasm VM from the tish repo); skip only
# its generated TypeScript types.
vendor/*.d.ts
