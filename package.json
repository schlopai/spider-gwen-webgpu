{
  "name": "spider3-tish",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "spider3 WebGPU engine ported to tish — written in tish, compiled to bytecode, run on a wasm VM, rendered with WebGPU, bundled with Vite.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:runtime": "bash build-runtime.sh",
    "build:assets": "bash build-assets.sh",
    "clean": "rm -rf dist gen"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "vite": "^8.0.14",
    "wasm-opt": "^1.4.0"
  },
  "dependencies": {
    "meshoptimizer": "^1.1.1"
  }
}
